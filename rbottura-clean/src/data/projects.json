        {
          "id": "zagreb",
          "title": "Propagation Workshop #2",
          "description": "EPE workshop residency at University of Zagreb Faculty of Graphic Arts.",
          "longDescription": "Propagation workshops explore Web-to-print by engaging students in collaborative editorial projects. Using HTML, CSS, and JavaScript, they create printed outputs from web-based content while testing the limits of these tools. The process unfolds in two phases: first, designing a printed booklet from provided materials; then, developing interactive screen-based publications that can also be printed, highlighting the connection between digital and physical formats.",
          "tags": ["web2print", "workshop"],
          "dates": { "year": "2024" },
          "preview": {
            "type": "gallery"
          },
          
          "media": {
            "path": "/medias/EPE_wk/",
            "images": [
              {"src": "epe_zagreb_group.jpg", "caption": "Workshop participants"},
              {"src": "epe_zagreb_group2.jpg", "caption": "Group work session"},
              {"src": "epe_zagreb_group3.jpg", "caption": "Productions and documentations"}
            ]
          },
          
          "links": [
            { "label": "EPE website", "url": "https://epe.esad-gv.fr" }
          ]
        },
        {
          "id": "izmir",
          "title": "Propagation Workshop #3",
          "description": "EPE workshop residency at Izmir University of economics, Visual Communication Department.",
          "longDescription": "Propagation workshops introduce Web-to-print tools through collaborative student projects hosted by partner schools. Using HTML, CSS, and JavaScript, participants learn to create printed editorial objects from web-based content, exploring both possibilities and limits. The workshops are structured in two phases: first, designing a printed booklet from given materials; second, developing interactive web publications that can also be printed. This final phase emphasizes the link between screen and print, requiring each project to include an interactive website component with printable outputs.",
          "tags": ["web2print", "workshop"],
          "dates": { "year": "2024" },
          "preview": {
            "type": "gallery"
          },
          "media": {
            "path": "/medias/EPE_wk/",
            "images": [
              {"src": "epe_izmir_wk.jpg", "caption": "Presentations of past workshops productions"},
              {"src": "epe_izmir_wk2.jpg", "caption": "Workshop session"},
              {"src": "epe_izmir_wk3.jpg", "caption": "Workshop session"}
            ]
          },
          "links": [
            { "label": "EPE website", "url": "https://epe.esad-gv.fr" }
          ]
        },
        {
          "id": "pagora",
          "title": "Prototyping Workshop #1 ",
          "description": "EPE workshop residency at Pagora, École internationale du papier, de la communication imprimée et des biomatériaux (Grenoble).",
          "longDescription": "The EPE prototyping phase focused on refining web-to-print workflows through a 5-day workshop at Pagora (Dec 2024). Collaborating with printing engineers, participants explored key technical limits of browser-based PDF generation, especially color separation (CMYK layers) and rasterization processes required for industrial printing. The workshop questioned how to achieve professional print compatibility from web tools. A major goal was to prototype alternative image-processing tools, enabling designers to control color layers and halftone patterns without relying on Adobe software, drawing inspiration from p5.js libraries like p5.riso and p5.FIP.",
          "tags": ["web2print", "workshop"],
          "dates": { "year": "2024" },
          "preview": {
            "type": "gallery"
          },
          "media": {
            "path": "/medias/EPE_wk/",
            "images": [
              {"src": "epe_pagora_wk.jpg", "caption": "Workshop session at Pagora"},
              {"src": "epe_pagora_wk2.jpg", "caption": "Process image with halftone patterns and color separation by prototyped tools made by students"},
              {"src": "epe_pagora_wk3.jpg", "caption": "Final project presentations"}
            ]
          },
          "links": [
            { "label": "EPE website", "url": "https://epe.esad-gv.fr" }
          ]
        },
        {
          "id": "hexagone",
          "title": "Production Workshop",
          "description": "EPE workshop residency at Théâtre Hexagone, Meylan (Grenoble).",
          "longDescription":"The Production workshop concludes the EPE program, following 5 workshops and ~25 experimental projects combining web and print. After phases of Propagation and Prototyping, it tests full-scale production in a near-professional context. Partnering with the Hexagone theater, the workshop focuses on improving visibility of artist residencies. Participants develop editorial workflows to showcase these activities through web-to-print outputs, using materials like texts, images, and recordings.",
          "dates": { "year": "2024" },
          "tags": ["web2print", "workshop"],
          "preview": {
            "type": "gallery"
          },
          "media": {
            "path": "/medias/EPE_wk/",
            "images": [
              {"src": "epe_hexagone_wk.jpg", "caption": "Workshop session at Hexagone open space"},
              {"src": "epe_hexagone_wk2.jpg", "caption": "Roundtable with contributors of the workshops and guests"},
              {"src": "epe_hexagone_wk3.jpeg", "caption": "Photo of liflets produced during the workshop"}
            ]
          },
          "links": [
            { "label": "EPE website", "url": "https://epe.esad-gv.fr" }
          ]
        }
      ]
